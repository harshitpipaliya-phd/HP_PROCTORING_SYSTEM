# HP Proctoring Backend — Environment Variables
# ==============================================
# Copy this file to .env and fill in your actual values.
# NEVER commit a .env file with real credentials to version control.
# Add .env to your .gitignore (it already is in this project).

# ── Application ──────────────────────────────
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Supabase Database ─────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── JWT Authentication ────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_KEY_MIN_32_CHARS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Inter-service API Key ─────────────────────
# Used by AI workers to call the main API (X-Internal-API-Key header)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=REPLACE_WITH_SECURE_RANDOM_KEY

# ── Cloudinary (Media Storage) ────────────────
# Get from: https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET

# ── HP Webhook ────────────────────────────────
# Set the outbound URL where HP receives proctoring results
HP_WEBHOOK_URL=https://your-hp-instance.example.com/webhook
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
HP_WEBHOOK_SECRET=REPLACE_WITH_SECURE_RANDOM_KEY

# ── Redis (Event Bus + Celery) ────────────────
# Local dev: redis://localhost:6379/0
# Production: your managed Redis URL (Render, Upstash, etc.)
REDIS_URL=redis://localhost:6379/0

# ── AI Worker ────────────────────────────────
# URL of the deployed ai_workers FastAPI service
AI_WORKER_URL=http://localhost:8001

# ── Video / Detection Settings ───────────────
VIDEO_MAX_FPS=15
VIDEO_FRAME_SKIP=1
RISK_THRESHOLD=50

# ── Audio Settings ────────────────────────────
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_SIZE=512

# ── Screen Monitoring ─────────────────────────
MONITOR_CHECK_INTERVAL=5
SCREENSHOT_DIR=static/screenshots

# ── Report Storage ────────────────────────────
REPORT_DIR=static/reports

# ── Model Paths ───────────────────────────────
AUDIO_MODEL_PATH=models/audio_classifier.pkl
MODEL_META_PATH=models/model_meta.json
