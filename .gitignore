# ── Secrets & credentials (NEVER commit) ─────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.coverage
coverage.xml
htmlcov/

# ── Virtual environments ──────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Models (large binary files) ──────────────────────────────────────────
*.pt
*.pkl
*.h5
*.onnx
models/*.pkl
models/*.json

# ── Logs & runtime ────────────────────────────────────────────────────────
logs/*.log
*.log
*.pid

# ── Static generated files ────────────────────────────────────────────────
static/screenshots/*.png
static/screenshots/*.jpg
static/reports/*.pdf
!static/screenshots/.gitkeep
!static/reports/.gitkeep

# ── IDE ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────
